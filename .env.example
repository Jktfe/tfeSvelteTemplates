# Environment Variables Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ===================================
# DATABASE CONFIGURATION
# ===================================

# Neon Database Connection String
# Get this from your Neon console: https://console.neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
# Example (DO NOT USE): postgresql://username:password123@ep-example-abc123.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://username:password@host.neon.tech/dbname?sslmode=require

# ===================================
# SETUP INSTRUCTIONS
# ===================================
#
# 1. Create a Neon database at https://neon.tech
#
# 2. Copy your connection string from the Neon console
#
# 3. Run the schema.sql file to create the cards table:
#    - Open your Neon SQL Editor
#    - Copy and paste the contents of /database/schema.sql
#    - Execute the SQL to create the table and insert sample data
#
# 4. Copy this file to .env:
#    cp .env.example .env
#
# 5. Replace the DATABASE_URL value with your actual connection string
#
# 6. Start the development server:
#    npm run dev
#
# ===================================
# TROUBLESHOOTING
# ===================================
#
# If you see "DATABASE_URL not configured" warnings:
# - Ensure your .env file exists in the project root
# - Verify the DATABASE_URL is set correctly
# - Restart your development server after changing .env
#
# Component demo pages show labelled fixture data if DATABASE_URL is not set,
# but write flows and auth require a real database.

# ===================================
# BETTER AUTH CONFIGURATION
# ===================================
# Better Auth uses the project database for users, sessions, accounts,
# and verification records.

# Generate a long random value:
# openssl rand -base64 32
BETTER_AUTH_SECRET=replace_with_a_long_random_secret

# Public app origin used by Better Auth callbacks/cookies.
BETTER_AUTH_URL=http://localhost:5173

# ===================================
# BETTER AUTH SETUP INSTRUCTIONS
# ===================================
#
# 1. Configure DATABASE_URL with your Neon/Postgres connection string
#
# 2. Set BETTER_AUTH_SECRET to a long random value
#
# 3. Run database/schema_better_auth.sql, or regenerate it with:
#    bunx @better-auth/cli@latest generate --config src/lib/server/betterAuth.ts --output database/schema_better_auth.sql -y
#
# 4. Restart your development server
#
# Auth pages will show "Auth Offline" until DATABASE_URL,
# BETTER_AUTH_SECRET, and BETTER_AUTH_URL are configured.

# ===================================
# OPTIONAL LOCAL DEMO USER
# ===================================
# Run this manually when you want a known local login for demos:
# bun run seed:demo-user
#
# For the hosted OSS demo only, expose the demo credentials on the sign-in page:
# PUBLIC_DEMO_AUTH=true
#
# Defaults:
# DEMO_USER_EMAIL=tester@test.com
# DEMO_USER_PASSWORD=test1
# DEMO_USER_NAME=Demo Tester
# PUBLIC_DEMO_USER_EMAIL=tester@test.com
# PUBLIC_DEMO_USER_PASSWORD=test1
